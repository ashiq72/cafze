# Cafze frontend environment
# Copy this file to .env.local for local development.
# NEXT_PUBLIC_* values are exposed to the browser. Never put secrets here.

# Base360 API origin (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Must match an active tenant in Base360
NEXT_PUBLIC_TENANT_ID=free4mood

# Authentication endpoint overrides
NEXT_PUBLIC_AUTH_LOGIN_PATH=/api/v1/auth/login
NEXT_PUBLIC_AUTH_REGISTER_PATH=/api/v1/users/create-user
NEXT_PUBLIC_AUTH_ME_PATH=/api/v1/users/me
NEXT_PUBLIC_AUTH_VERIFY_PATH=/api/v1/auth/verify-email
NEXT_PUBLIC_AUTH_RESEND_PATH=/api/v1/auth/resend-verification
NEXT_PUBLIC_AUTH_PROFILE_PATH=/api/v1/users/update-user
NEXT_PUBLIC_AUTH_CHANGE_PASSWORD_PATH=/api/v1/auth/change-password
